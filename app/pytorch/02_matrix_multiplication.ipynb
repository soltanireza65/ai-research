   "source": [
    "A = torch.tensor([[1., 2., 3.], [4., 5., 6.]])\n",
    "B = torch.tensor([[1.], [2.], [3.]])\n",
    "print('A @ B =\\n', A @ B)\n",
    "print('shape:', (A @ B).shape)"
   ]
